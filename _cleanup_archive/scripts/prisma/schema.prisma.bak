generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String
  slug                    String                   @unique
  createdAt               DateTime?                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime?                @default(now()) @map("updated_at") @db.Timestamptz(6)
  status                  TenantStatus             @default(PENDING)
  appointments            Appointment[]
  expenses                Expense[]
  inventory               Inventory[]
  invoiceItems            InvoiceItem[]
  invoices                Invoice[]
  labOrders               LabOrder[]
  medicalConditions       MedicalCondition[]
  oralConditions          OralCondition[]
  oralTissueFindings      OralTissueFinding[]
  patientAllergies        PatientAllergy[]
  patientDocuments        PatientDocument[]
  patientFamilyHistory    PatientFamilyHistory[]
  patientMedications      PatientMedication[]
  patientSurgeries        PatientSurgery[]
  patients                Patient[]
  payments                Payment[]
  periodontalMeasurements PeriodontalMeasurement[]
  prescriptionItems       PrescriptionItem[]
  prescriptions           Prescription[]
  services                Service[]
  staff                   Staff[]
  toothConditions         ToothCondition[]
  treatmentPlanItems      TreatmentPlanItem[]
  treatmentPlans          TreatmentPlan[]
  users                   User[]
  visitRecords            VisitRecord[]

  @@index([createdAt])
  @@map("tenants")
}

model User {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supabaseId String    @unique @map("supabase_id")
  email      String    @unique
  tenantId   String    @map("tenant_id") @db.Uuid
  role       String?   @default("USER")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  staffId    String?   @unique @map("staff_id") @db.Uuid
  staff      Staff?    @relation(fields: [staffId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([supabaseId])
  @@index([tenantId])
  @@map("users")
}

model Staff {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId       String?        @unique @map("display_id")
  name            String
  role            StaffRole
  title           String?
  email           String         @unique
  phone           String?
  status          String?        @default("Online")
  createdAt       DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?      @default(now()) @map("updated_at") @db.Timestamptz(6)
  avatarUrl       String?        @map("avatar_url")
  tenantId        String         @map("tenant_id") @db.Uuid
  inviteAccepted  Boolean        @default(false) @map("invite_accepted")
  inviteExpiresAt DateTime?      @map("invite_expires_at")
  inviteToken     String?        @unique @map("invite_token")
  appointments    Appointment[]
  prescriptions   Prescription[]
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user            User?

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@index([inviteToken])
  @@map("staff")
}

model Patient {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId               String?                  @unique @map("display_id")
  name                    String
  email                   String?
  phone                   String?
  dob                     DateTime?                @db.Date
  gender                  String?
  bloodGroup              String?                  @map("blood_group")
  avatarInitials          String?                  @map("avatar_initials")
  colorGradient           String?                  @map("color_gradient")
  createdAt               DateTime?                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime?                @default(now()) @map("updated_at") @db.Timestamptz(6)
  phone2                  String?
  address                 String?
  postCode                String?                  @map("post_code")
  city                    String?
  maritalStatus           String?                  @map("marital_status")
  occupation              String?
  insurance               String?
  ssn                     String?
  idNumber                String?                  @map("id_number")
  medicalAlert            String?                  @map("medical_alert")
  referredBy              String?                  @map("referred_by")
  notes                   String?
  isDeceased              Boolean?                 @default(false) @map("is_deceased")
  isSigned                Boolean?                 @default(false) @map("is_signed")
  status                  String?                  @default("Active")
  smokingStatus           String?                  @default("Never") @map("smoking_status")
  alcoholUse              String?                  @default("None") @map("alcohol_use")
  medicalNotes            String?                  @map("medical_notes")
  tenantId                String                   @map("tenant_id") @db.Uuid
  appointments            Appointment[]
  invoices                Invoice[]
  labOrders               LabOrder[]
  medicalConditions       MedicalCondition[]
  oralConditions          OralCondition[]
  oralTissueFindings      OralTissueFinding[]
  patientAllergies        PatientAllergy[]
  patientDocuments        PatientDocument[]
  patientFamilyHistory    PatientFamilyHistory[]
  patientMedications      PatientMedication[]
  patientSurgeries        PatientSurgery[]
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  periodontalMeasurements PeriodontalMeasurement[]
  prescriptions           Prescription[]
  toothConditions         ToothCondition[]
  treatmentPlans          TreatmentPlan[]
  visitRecords            VisitRecord[]

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("patients")
}

model Appointment {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String             @map("patient_id") @db.Uuid
  doctorId  String             @map("doctor_id") @db.Uuid
  serviceId String?            @map("service_id") @db.Uuid
  date      DateTime           @db.Date
  time      DateTime           @db.Time(6)
  duration  Int
  notes     String?
  createdAt DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?          @default(now()) @map("updated_at") @db.Timestamptz(6)
  displayId String?            @unique @map("display_id")
  treatment String?
  color     String?
  tenantId  String             @map("tenant_id") @db.Uuid
  status    AppointmentStatus? @default(SCHEDULED)
  doctor    Staff              @relation(fields: [doctorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient   Patient            @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  service   Service?           @relation(fields: [serviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  invoice   Invoice?
  labOrders LabOrder[]

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("appointments")
}

model Service {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  price              Decimal                 @db.Decimal
  description        String?
  popular            Boolean?                @default(false)
  createdAt          DateTime?               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime?               @default(now()) @map("updated_at") @db.Timestamptz(6)
  duration           Int
  tenantId           String                  @map("tenant_id") @db.Uuid
  isActive           Boolean                 @default(true) @map("is_active")
  category           ServiceCategory
  appointments       Appointment[]
  inventoryUsages    ServiceInventoryUsage[]
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  treatmentPlanItems TreatmentPlanItem[]

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("services")
}

model Invoice {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId     String?        @unique @map("display_id")
  patientId     String         @map("patient_id") @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  appointmentId String?        @unique @map("appointment_id") @db.Uuid

  totalAmount Decimal @map("total_amount") @db.Decimal
  paidAmount  Decimal @default(0) @map("paid_amount") @db.Decimal

  status  InvoiceStatus @default(PENDING)
  dueDate DateTime?     @map("due_date") @db.Date

  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  // Legacy field support (optional, can be removed if not needed)
  treatment String?

  appointment Appointment?  @relation(fields: [appointmentId], references: [id])
  patient     Patient       @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items       InvoiceItem[]
  payments    Payment[]

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId String  @map("invoice_id") @db.Uuid
  serviceId String? @map("service_id") @db.Uuid

  description String
  quantity    Int     @default(1)
  price       Decimal @db.Decimal

  tenantId String  @map("tenant_id") @db.Uuid
  invoice  Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, invoiceId])
  @@map("invoice_items")
}

model Payment {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId String        @map("invoice_id") @db.Uuid
  amount    Decimal       @db.Decimal
  method    PaymentMethod
  paidAt    DateTime      @default(now()) @map("paid_at") @db.Timestamptz(6)
  notes     String?

  tenantId String  @map("tenant_id") @db.Uuid
  invoice  Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, invoiceId])
  @@map("payments")
}

model Expense {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId   String?        @unique @map("display_id")
  category    String
  description String
  amount      Decimal        @db.Decimal
  date        DateTime       @db.Date
  createdAt   DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?      @default(now()) @map("updated_at") @db.Timestamptz(6)
  method      String?
  tenantId    String         @map("tenant_id") @db.Uuid
  status      ExpenseStatus? @default(PENDING)
  notes       String?
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("expenses")
}

model Inventory {
  id        String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId String?                 @unique @map("display_id")
  name      String
  category  String
  quantity  Int                     @default(0)
  minLevel  Int                     @default(10) @map("min_level")
  unit      String?
  createdAt DateTime?               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?               @default(now()) @map("updated_at") @db.Timestamptz(6)
  minStock  Int?                    @default(0) @map("min_stock")
  location  String?
  supplier  String?
  tenantId  String                  @map("tenant_id") @db.Uuid
  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usages    ServiceInventoryUsage[]

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("inventory")
}

model ServiceInventoryUsage {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId   String    @map("service_id") @db.Uuid
  inventoryId String    @map("inventory_id") @db.Uuid
  quantity    Int       @default(1)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  tenantId    String    @map("tenant_id") @db.Uuid
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, inventoryId])
  @@index([tenantId, serviceId])
  @@map("service_inventory_usage")
}

model LabOrder {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId     String? @unique @map("display_id")
  tenantId      String  @map("tenant_id") @db.Uuid
  patientId     String  @map("patient_id") @db.Uuid
  appointmentId String? @map("appointment_id") @db.Uuid

  labName     String         @map("lab_name")
  itemType    String         @map("item_type")
  toothNumber String?        @map("tooth_number")
  status      LabOrderStatus @default(PENDING)

  sentAt     DateTime? @map("sent_at") @db.Timestamptz(6)
  dueDate    DateTime? @map("due_date") @db.Date
  receivedAt DateTime? @map("received_at") @db.Timestamptz(6)

  cost      Decimal?  @db.Decimal
  notes     String?
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("lab_orders")
}

model TreatmentPlan {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String              @map("patient_id") @db.Uuid
  title     String
  status    String?             @default("Active")
  notes     String?
  createdAt DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?           @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenantId  String              @map("tenant_id") @db.Uuid
  items     TreatmentPlanItem[]
  patient   Patient             @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("treatment_plans")
}

model TreatmentPlanItem {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId        String        @map("plan_id") @db.Uuid
  serviceId     String?       @map("service_id") @db.Uuid
  serviceName   String        @map("service_name")
  toothList     String?       @map("tooth_list")
  price         Decimal       @db.Decimal
  status        String?       @default("Planned")
  createdAt     DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?     @default(now()) @map("updated_at") @db.Timestamptz(6)
  step          Int?
  scheduledDate DateTime?     @map("scheduled_date") @db.Date
  notes         String?
  tenantId      String        @map("tenant_id") @db.Uuid
  plan          TreatmentPlan @relation(fields: [planId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  service       Service?      @relation(fields: [serviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("treatment_plan_items")
}

model Prescription {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId  String             @map("patient_id") @db.Uuid
  doctorId   String?            @map("doctor_id") @db.Uuid
  date       DateTime?          @default(now()) @map("date") @db.Timestamptz(6)
  notes      String?
  createdAt  DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime?          @default(now()) @map("updated_at") @db.Timestamptz(6)
  doctorName String?            @map("doctor_name")
  tenantId   String             @map("tenant_id") @db.Uuid
  items      PrescriptionItem[]
  doctor     Staff?             @relation(fields: [doctorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient    Patient            @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prescriptionId String       @map("prescription_id") @db.Uuid
  medicationName String       @map("medication_name")
  dosage         String?
  frequency      String?
  duration       String?
  createdAt      DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  tenantId       String       @map("tenant_id") @db.Uuid
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("prescription_items")
}

model PatientAllergy {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String    @map("patient_id") @db.Uuid
  severity  String?   @default("outline")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenantId  String    @map("tenant_id") @db.Uuid
  allergen  String?
  notes     String?
  reaction  String?
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("patient_allergies")
}

model MedicalCondition {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  diagnosedDate DateTime? @map("diagnosed_date") @db.Date
  status        String?
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenantId      String    @map("tenant_id") @db.Uuid
  conditionName String?   @map("condition_name")
  notes         String?
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("medical_conditions")
}

model PatientMedication {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId      String    @map("patient_id") @db.Uuid
  dosage         String?
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenantId       String    @map("tenant_id") @db.Uuid
  frequency      String?
  medicationName String?   @map("medication_name")
  notes          String?
  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("patient_medications")
}

model VisitRecord {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String    @map("patient_id") @db.Uuid
  date      DateTime  @db.Date
  treatment String
  doctor    String
  notes     String?
  tooth     String?
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenantId  String    @map("tenant_id") @db.Uuid
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("visit_records")
}

model ToothCondition {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String    @map("patient_id") @db.Uuid
  toothNumber Int       @map("tooth_number")
  condition   String
  notes       String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenantId    String    @map("tenant_id") @db.Uuid
  isMissing   Boolean   @default(false) @map("is_missing")
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tenantId, patientId, toothNumber])
  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("tooth_conditions")
}

model OralCondition {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String    @map("patient_id") @db.Uuid
  name      String
  active    Boolean?  @default(true)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenantId  String    @map("tenant_id") @db.Uuid
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tenantId, patientId, name])
  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("oral_conditions")
}

model OralTissueFinding {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String    @map("patient_id") @db.Uuid
  name      String
  status    String
  notes     String?
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenantId  String    @map("tenant_id") @db.Uuid
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tenantId, patientId, name])
  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("oral_tissue_findings")
}

model PeriodontalMeasurement {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId       String?   @map("patient_id") @db.Uuid
  toothNumber     Int       @map("tooth_number")
  parameterName   String    @map("parameter_name")
  buccalValues    Int[]     @map("buccal_values")
  lingualValues   Int[]     @map("lingual_values")
  singleValue     Int?      @map("single_value")
  measurementDate DateTime? @default(now()) @map("measurement_date") @db.Date
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  tenantId        String    @map("tenant_id") @db.Uuid
  patient         Patient?  @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([patientId, toothNumber, parameterName], name: "patientId_toothNumber_parameterName")
  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("periodontal_measurements")
}

model PatientDocument {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId  String    @map("patient_id") @db.Uuid
  name       String
  type       String
  fileUrl    String    @map("file_url")
  uploadDate DateTime? @default(now()) @map("upload_date") @db.Timestamptz(6)
  tenantId   String    @map("tenant_id") @db.Uuid
  category   String?   @default("other")
  patient    Patient   @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, uploadDate])
  @@map("patient_documents")
}

model PatientSurgery {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String    @map("patient_id") @db.Uuid
  surgeryName String    @map("surgery_name")
  notes       String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenantId    String    @map("tenant_id") @db.Uuid
  surgeryDate DateTime? @map("surgery_date") @db.Date
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("patient_surgeries")
}

model PatientFamilyHistory {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  conditionName String    @map("condition_name")
  relation      String?
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenantId      String    @map("tenant_id") @db.Uuid
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("patient_family_history")
}

enum TenantStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StaffRole {
  ADMIN
  DOCTOR
  ASSISTANT
  RECEPTIONIST

  @@map("staff_role")
}

enum AppointmentStatus {
  SCHEDULED
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("appointment_status")
}

enum InvoiceStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  CANCELLED

  @@map("invoice_status")
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER

  @@map("payment_method")
}

enum ExpenseStatus {
  PAID
  PENDING

  @@map("expense_status")
}

enum LabOrderStatus {
  PENDING
  SENT
  IN_PROGRESS
  RECEIVED
  DELIVERED
  CANCELLED

  @@map("lab_order_status")
}

enum ServiceCategory {
  PREVENTIVE
  RESTORATIVE
  SURGICAL
  ORTHODONTICS

  @@map("service_category")
}
